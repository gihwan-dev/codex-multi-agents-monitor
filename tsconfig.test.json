{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".tmp-tests",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022"
  },
  "include": [
    "src/shared/domain/**/*.ts",
    "src/features/fixtures/**/*.ts",
    "src/features/ingestion/**/*.ts",
    "tests/**/*.ts"
  ]
}
