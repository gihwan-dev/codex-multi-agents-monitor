{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/schemas/codex-multi-agent-monitor-v0-1.json",
  "title": "Codex Multi-Agent Monitor v0.1 Normalized Trace Envelope",
  "description": "Internal normalized contract for completed import and local watch. Preview fields are stored by default; raw payload references are opt-in only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "captured_at",
    "project",
    "session",
    "run",
    "lanes",
    "events",
    "edges",
    "summary",
    "privacy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "project": {
      "$ref": "#/definitions/Project"
    },
    "session": {
      "$ref": "#/definitions/Session"
    },
    "run": {
      "$ref": "#/definitions/RunTrace"
    },
    "lanes": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/AgentLane"
      }
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/EventObservation"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/EdgeLink"
      }
    },
    "summary": {
      "$ref": "#/definitions/SummaryContract"
    },
    "privacy": {
      "$ref": "#/definitions/PrivacyPolicy"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "label"],
        "properties": {
          "artifact_id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "uri": {
            "type": "string"
          }
        }
      }
    }
  },
  "definitions": {
    "StatusEnum": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "waiting",
        "blocked",
        "interrupted",
        "done",
        "failed",
        "cancelled"
      ]
    },
    "EventTypeEnum": {
      "type": "string",
      "enum": [
        "run.started",
        "run.finished",
        "run.failed",
        "run.cancelled",
        "agent.spawned",
        "agent.state_changed",
        "agent.finished",
        "llm.started",
        "llm.finished",
        "tool.started",
        "tool.finished",
        "handoff",
        "transfer",
        "error",
        "note"
      ]
    },
    "EdgeTypeEnum": {
      "type": "string",
      "enum": ["spawn", "handoff", "transfer", "merge"]
    },
    "Project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "name"],
      "properties": {
        "project_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "repo_root": {
          "type": "string"
        },
        "environment": {
          "type": "string",
          "description": "Example: local, worktree, cloud."
        }
      }
    },
    "Session": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "title"],
      "properties": {
        "session_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "ended_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "RunTrace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "project_id", "session_id", "title", "status", "ingest_mode"],
      "properties": {
        "trace_id": {
          "type": "string"
        },
        "project_id": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/StatusEnum"
        },
        "ingest_mode": {
          "type": "string",
          "enum": ["import", "watch"]
        },
        "start_ts": {
          "type": "string",
          "format": "date-time"
        },
        "end_ts": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "AgentLane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lane_id", "agent_id", "thread_id", "name", "status"],
      "properties": {
        "lane_id": {
          "type": "string"
        },
        "agent_id": {
          "type": "string"
        },
        "thread_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/StatusEnum"
        },
        "parent_lane_id": {
          "type": "string"
        },
        "worktree_ref": {
          "type": "string"
        }
      }
    },
    "EventObservation": {
      "type": "object",
      "additionalProperties": false,
      "description": "Stable shape contract for a normalized event. Non-applicable fields must be present as explicit null values instead of being omitted. `raw_payload_ref` remains an opt-in reference.",
      "required": [
        "project_id",
        "session_id",
        "trace_id",
        "event_id",
        "agent_id",
        "thread_id",
        "parent_id",
        "link_ids",
        "start_ts",
        "end_ts",
        "duration_ms",
        "event_type",
        "status",
        "wait_reason",
        "retry_count",
        "source_agent_id",
        "target_agent_id",
        "edge_type",
        "provider",
        "model",
        "tool_name",
        "api_type",
        "tokens_in",
        "tokens_out",
        "cache_read_tokens",
        "cache_write_tokens",
        "cost_usd",
        "finish_reason",
        "title",
        "input_preview",
        "output_preview",
        "artifact_ref",
        "error_code",
        "error_message"
      ],
      "properties": {
        "project_id": {
          "type": "string"
        },
        "session_id": {
          "type": "string"
        },
        "trace_id": {
          "type": "string"
        },
        "event_id": {
          "type": "string"
        },
        "agent_id": {
          "type": "string"
        },
        "thread_id": {
          "type": "string"
        },
        "parent_id": {
          "type": ["string", "null"]
        },
        "link_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "start_ts": {
          "type": "string",
          "format": "date-time"
        },
        "end_ts": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "duration_ms": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "event_type": {
          "$ref": "#/definitions/EventTypeEnum"
        },
        "status": {
          "$ref": "#/definitions/StatusEnum"
        },
        "wait_reason": {
          "type": ["string", "null"],
          "description": "Always present for stable shape. Must be a string when status is waiting, blocked, or interrupted; otherwise null is allowed."
        },
        "retry_count": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "source_agent_id": {
          "type": ["string", "null"]
        },
        "target_agent_id": {
          "type": ["string", "null"]
        },
        "edge_type": {
          "type": ["string", "null"],
          "enum": ["spawn", "handoff", "transfer", "merge", null]
        },
        "provider": {
          "type": ["string", "null"]
        },
        "model": {
          "type": ["string", "null"]
        },
        "tool_name": {
          "type": ["string", "null"]
        },
        "api_type": {
          "type": ["string", "null"]
        },
        "tokens_in": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "tokens_out": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "cache_read_tokens": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "cache_write_tokens": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "cost_usd": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "finish_reason": {
          "type": ["string", "null"]
        },
        "title": {
          "type": ["string", "null"]
        },
        "input_preview": {
          "type": ["string", "null"],
          "description": "Stored by default. Keep concise and redaction-friendly."
        },
        "output_preview": {
          "type": ["string", "null"],
          "description": "Stored by default. Keep concise and redaction-friendly."
        },
        "raw_payload_ref": {
          "type": "string",
          "description": "Optional reference only. Raw payload capture is opt-in."
        },
        "artifact_ref": {
          "type": ["string", "null"]
        },
        "error_code": {
          "type": ["string", "null"]
        },
        "error_message": {
          "type": ["string", "null"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "enum": ["waiting", "blocked", "interrupted"]
              }
            },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "wait_reason": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": ["wait_reason"]
          }
        }
      ]
    },
    "EdgeLink": {
      "type": "object",
      "additionalProperties": false,
      "required": ["edge_id", "trace_id", "edge_type", "source_agent_id", "target_agent_id"],
      "properties": {
        "edge_id": {
          "type": "string"
        },
        "trace_id": {
          "type": "string"
        },
        "edge_type": {
          "$ref": "#/definitions/EdgeTypeEnum"
        },
        "source_agent_id": {
          "type": "string"
        },
        "target_agent_id": {
          "type": "string"
        },
        "source_event_id": {
          "type": "string"
        },
        "target_event_id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "SummaryContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "duration",
        "active_time",
        "idle_time",
        "agent_count",
        "peak_parallelism",
        "llm_calls",
        "tool_calls",
        "total_tokens",
        "total_cost",
        "error_count"
      ],
      "properties": {
        "duration": {
          "type": "number",
          "minimum": 0
        },
        "active_time": {
          "type": "number",
          "minimum": 0
        },
        "idle_time": {
          "type": "number",
          "minimum": 0
        },
        "agent_count": {
          "type": "integer",
          "minimum": 0
        },
        "peak_parallelism": {
          "type": "integer",
          "minimum": 0
        },
        "llm_calls": {
          "type": "integer",
          "minimum": 0
        },
        "tool_calls": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_cost": {
          "type": "number",
          "minimum": 0
        },
        "error_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "PrivacyPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["store_raw_payloads", "export_raw_by_default", "sensitive_storage_disabled"],
      "properties": {
        "store_raw_payloads": {
          "type": "boolean",
          "default": false,
          "description": "False by default. Raw capture is opt-in."
        },
        "export_raw_by_default": {
          "type": "boolean",
          "default": false
        },
        "sensitive_storage_disabled": {
          "type": "boolean",
          "default": false,
          "description": "Project-level switch to prevent sensitive payload storage."
        },
        "redaction_hook": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
